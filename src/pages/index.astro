---
import Layout from '../layouts/Layout.astro';
import ProductCard from '../components/ProductCard.astro';
import { getCollection } from 'astro:content';

const allProducts = await getCollection('products');
const featured = allProducts.filter(p => p.data.featured);
---

<Layout title="The Shop — Books & Board Games">
  <section class="hero">
    <h1>Books, Board Games & More</h1>
    <p>A curated selection of our favorite things to read and play.</p>
    <a href="/products" class="browse-btn">Browse All Products</a>
  </section>

  {featured.length > 0 && (
    <section class="featured">
      <h2>Featured</h2>
      <div class="product-grid">
        {featured.map(product => (
          <ProductCard
            id={product.id}
            title={product.data.title}
            description={product.data.description}
            price={product.data.price}
            stock={product.data.stock}
            image={product.data.image}
            category={product.data.category}
            url={`/products/${product.id}`}
          />
        ))}
      </div>
    </section>
  )}
</Layout>

<style>
  .hero {
    text-align: center;
    padding: 4rem 1rem;
  }

  .hero h1 {
    font-size: 2.5rem;
    margin: 0 0 1rem;
  }

  .hero p {
    font-size: 1.125rem;
    color: var(--color-muted);
    margin: 0 0 2rem;
  }

  .browse-btn {
    display: inline-block;
    background: var(--color-accent);
    color: #fff;
    text-decoration: none;
    padding: 0.75rem 1.75rem;
    border-radius: var(--radius);
    font-weight: 500;
  }

  .browse-btn:hover {
    background: var(--color-accent-hover);
    color: #fff;
  }

  .featured h2 {
    font-size: 1.5rem;
    margin: 0 0 1.5rem;
  }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }
</style>
